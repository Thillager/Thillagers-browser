{
    "bin": {"demo": "jdeploy-bundle/jdeploy.js"},
    "author": "Thillager",
    "description": "My own browser",
    "main": "index.js",
    "preferGlobal": true,
    "repository": {"url": "https://github.com/Thillager/Thillagers-browser"},
    "version": "1.0.0",
    "jdeploy": {
        "fallbackToUniversal": false,
        "generateLegacyBundles": false,
        "publishTargets": [{
            "name": "github: github",
            "type": "GITHUB",
            "url": "https://github.com/Thillager/Thillagers-browser"
        }],
        "javaVersion": "17",
        "javafx": true,
        "title": "Thillagers-browser",
        "platformBundlesEnabled": false,
        "downloadPage": {"platforms": ["default"]}
    },
    "dependencies": {
        "command-exists-promise": "^2.0.2",
        "node-fetch": "2.6.7",
        "tar": "^4.4.8",
        "yauzl": "^2.10.0",
        "shelljs": "^0.8.4"
    },
    "license": "ISC",
    "name": "Thillagers-browser",
    "files": ["jdeploy-bundle"],
    "scripts": {"test": "echo \"Error: no test specified\" && exit 1"}
}